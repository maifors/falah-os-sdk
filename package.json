{
  "name": "@falah/sdk",
  "version": "1.2.0",
  "description": "The official Falah OS TypeScript SDK — sovereign identity, wallet, Shariah contracts, and events in one import.",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./identity": {
      "import": "./dist/identity/index.esm.js",
      "require": "./dist/identity/index.js",
      "types": "./dist/identity/index.d.ts"
    },
    "./wallet": {
      "import": "./dist/wallet/index.esm.js",
      "require": "./dist/wallet/index.js",
      "types": "./dist/wallet/index.d.ts"
    },
    "./contracts": {
      "import": "./dist/contracts/index.esm.js",
      "require": "./dist/contracts/index.js",
      "types": "./dist/contracts/index.d.ts"
    }
  },
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "tsc && echo 'Build complete'",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["falah-os", "islamic-finance", "shariah", "web3", "identity", "zk-proof", "halal"],
  "author": "Falah Consultancy Ltd",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/maifors/falah-os-sdk"
  },
  "homepage": "https://dev.falah-os.com",
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "ts-jest": "^29.0.0"
  }
}
